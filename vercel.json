{
    "rewrites": [
      {
        "source": "/register",
        "destination": "/register.html"
      },
      {
        "source": "/login",
        "destination": "/login.html"
      },
      {
        "source": "/",
        "destination": "/index.html"
      }
    ],

    "version":2,
    "builds": [
      { "src": "*.js", "use": "@vercel/node" }
    ],
    "routes": [
        {
          "src": "/(.*)",
          "dest": "/"
        }
    ]
  }
  